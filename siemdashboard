#flask must be installed in the terminal before usage (pip install flask)
from flask import Flask, render_template, request #flask is a tool used by developers to put their works into a website, as this code does.
import requests #this is a library for calling APIs

ipRepKey = "xxxx"

def checker(ipAddr, ipRepKey): #if you want to see more indepth, see "ipreputationchecker" in this repository
            headers = { #these headers essentially act as the what you want (accept), as well as your verification (apikey).
                "Key": ipRepKey,
                "Accept": "application/json"
            }
            params = { #the parameters are essentially the goods of what you requested.
                "ipAddress": ipAddr,
                "maxAgeInDays": 90
            }

            response = requests.get("https://api.abuseipdb.com/api/v2/check", headers=headers, params=params) #the format for requests is request.get(link, headers = x, params =  y)

            data = response.json()["data"] #this is the entirety of the data, specifically honed in at the "data" segment. its like opening a directory in linux, and data would be the directory youre in with this string of code
            
            checkedIp = data["ipAddress"] 
            abuseScore = data["abuseConfidenceScore"]
            country = data["countryCode"]
            isp = data["isp"]
            lastReport = data["lastReportedAt"]
            totalReports = data["totalReports"]
            
            if abuseScore == 0: #if the abuse score is 0...
                threat = "Clean"
            elif abuseScore >= 1 and abuseScore <= 50: #if the abuse score is less than 50 and above 1...
                threat = "Suspicious"
            elif abuseScore > 50: #if the abuse score is greater than 50..
                threat = "Dangerous"

            results = { #this data must be formatted for the results to be kept inside of a readable format for flask to read, in this case, a dictionary. If this data was in regular variables, then the formatting would be messy, so, putting data into a dictionary solves this issue
                "checkedIP": data["ipAddress"],
                "abuseScore": data["abuseConfidenceScore"],
                "country": data["countryCode"],
                "isp": data["isp"],
                "lastReport": data["lastReportedAt"],
                "totalReports": data["totalReports"],
                "overall": threat
            }

            return results #then, RETURN THE RESULTS SO IT CAN BE USED OUTSIDE OF THE FUNCTION

app = Flask(__name__) #this defines flask, and once "app.run" is called, then flask initiates, but first it needs to be assigned to a variable.

@app.route("/", methods=["GET", "POST"]) #this decorator tells the script that below is supposed to be ran once someome enters the site. "whenever someone visits "/", call the function listed below." also, "methods" tells flask what kind of requests its allowed to accept. in this case, its a "GET (meaning "give me the page basically")" and "POST (meaning "here's data, do xyz with it")"
def index(): #adding onto previous line. by default, flask already accepts GET, but by adding the methods section, it is essentially saying that this route should handle both people visiting the page, AND submitting the form. if "methods" was not present, flask throws an error due to flask refusing the post request by default
    website = render_template("index.html", title="Welcome") #this is standard formatting for flask. "index.html" is posted in the repository, and that serves for what goes into the website, formatted in html.
    if request.method == "POST": #if someone gives data to this website.... in other words, when someone fills out the form for this website....
        ipAddr = request.form.get("ipAddress") #the ipaddress that gets typed in the form becomes the variable for the ip repuation checker
        results = checker(ipAddr, ipRepKey) #call the function, and put it into a variable
        website = render_template("index.html", title="Welcome", results=results) #then, change the format of the website, and include the results. notice how similar this line looks to the previous render_template. 
        return website #then, give the website back to the user
    elif request.method == "GET": #if someone visits this wesbite...
        pass
    return website

app.run(debug=True) #run the website, with debug on.