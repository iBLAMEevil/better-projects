def scanPort(ipAddr2, scanStart, scanEnd, answer): #if you want to see more indepth, see "portscanner" in starterrepository
    results = [] 
    for i in range(scanStart, scanEnd): 
        try: 
            newSocket = socket.socket(socket.AF_INET, socket.SOCK_STREAM) 
            newSocket.settimeout(1) 
            newSocket.connect((ipAddr2, i)) 
            if i in service:
                results.append({"openPort": i, "service": service[i]})
            else:
                results.append({"openPort": i})
            newSocket.close() 
        except: 
            if answer.upper() == "YES":
                if i in service:
                    results.append({"closedPort": i, "service": service[i]})
                else:
                    results.append({"closedPort": i})
    return results


