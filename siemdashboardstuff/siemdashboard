def databaseInitiate(): #this is where making a database comes in. 
    database = sqlite3.connect("repchecker.db") #first, connect to the database on the computer
    database.execute("""
                    CREATE TABLE IF NOT EXISTS repchecker (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    ip_address TEXT,
                    abuse_score INTEGER,
                    threat TEXT,
                    date_checked TEXT)
                    """) #this is a standard format for inserting data into the database. it will make this table if it doesn't exist with those headers.
    database.execute("""
                     CREATE TABLE IF NOT EXISTS portscanHistory (
                     id INTEGER PRIMARY KEY AUTOINCREMENT,
                     ip_address TEXT,
                     start_port INTEGER,
                     end_port INTEGER,
                     open_ports TEXT,
                     date_checked TEXT)
                     """)
    database.commit() #then, save all changes to the database
    database.close() #then, close



#ip reputation checker stuff
ipRepKey = "xxxx"
def checker(ipAddr, ipRepKey): #if you want to see more indepth, see "ipreputationchecker" in this repository
    headers = { 
        "Key": ipRepKey,
        "Accept": "application/json"
    }
    params = { 
    "ipAddress": ipAddr,
    "maxAgeInDays": 90
    }

    try:
        response = requests.get("https://api.abuseipdb.com/api/v2/check", headers=headers, params=params) #the format for requests is request.get(link, headers = x, params =  y)

        data = response.json()["data"] #this is the entirety of the data, specifically honed in at the "data" segment. its like opening a directory in linux, and data would be the directory youre in with this string of code
            
        checkedIp = data["ipAddress"] 
        abuseScore = data["abuseConfidenceScore"]
        country = data["countryCode"]
        isp = data["isp"]
        lastReport = data["lastReportedAt"]
        totalReports = data["totalReports"]
                
        if abuseScore == 0: 
            threat = "Clean"
        elif abuseScore >= 1 and abuseScore <= 50: 
            threat = "Suspicious"
        elif abuseScore > 50: 
            threat = "Dangerous"

        results = { #this data must be formatted for the results to be kept inside of a readable format for flask to read, in this case, a dictionary. If this data was in regular variables, then the formatting would be messy, so, putting data into a dictionary solves this issue
            "checkedIP": data["ipAddress"],
            "abuseScore": data["abuseConfidenceScore"],
            "country": data["countryCode"],
            "isp": data["isp"],
            "lastReport": data["lastReportedAt"],
            "totalReports": data["totalReports"],
            "overall": threat
        }

        return results #then, RETURN THE RESULTS SO IT CAN BE USED OUTSIDE OF THE FUNCTION
    except KeyError:
        results = {"error": "API key invalid, double check the API key in the script"}
        return results

